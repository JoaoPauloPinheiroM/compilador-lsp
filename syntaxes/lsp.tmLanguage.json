{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "lsp",
	"patterns": [
		{ "include": "#comentarios" },
		{ "include": "#texto" },
		{ "include": "#declaracoes" },
		{ "include": "#metodos_objetos" },
		{ "include": "#propriedades_objetos" },
		{ "include": "#keywords" },
		{ "include": "#booleans" },
		{ "include": "#funcoes_nativas" },
		{ "include": "#funcoes_gigante_comunidade" },
		{ "include": "#variaveis_gigante_comunidade" },
		{ "include": "#constantes_erp" },
		{ "include": "#constantes_rh" },
		{ "include": "#variaveis_erp" },
		{ "include": "#variaveis_rh" },
		{ "include": "#numeros" },
		{ "include": "#operadores" },
		{ "include": "#variaveis_gerais" }
	],
	"repository": {
		"comentarios": {
			"patterns": [
				{ "name": "comment.line.at.lsp", "begin": "@", "end": "@|\\n" },
				{ "name": "comment.block.lsp", "begin": "/\\*", "end": "\\*/" }
			]
		},
		"texto": {
			"name": "string.quoted.double.lsp",
			"begin": "\"",
			"end": "\"",
			"patterns": [ { "name": "constant.character.escape.lsp", "match": "\\\\." } ]
		},
		"numeros": {
			"name": "constant.numeric.lsp",
			"match": "(?<!\\.)\\b\\d+(\\.\\d+)?([eE][\\-+]?\\d+)?\\b"
		},
		"keywords": {
			"patterns": [
				{ "name": "keyword.control.lsp", "match": "(?<!\\.)(?i)\\b(Inicio|Fim|Para|Enquanto|VaPara|Regra|Se|Senao|Cancel|Continue|Pare|End|E|Ou|Retorna|Erro|Refaz)\\b" },
				{ "name": "keyword.other.lsp", "match": "(?<!\\.)(?i)\\b(abrir|abrirarquivo|atualizarcampos|cancela|chamarfuncao|desabilitarbotao|desabilitarcampo|desabilitartodos|desfazertransacao|escondercampo|fechar|finalizartransacao|formatar|gravar|gravarnl|gravarnleol|grid|habilitarbotao|habilitarcampo|habilitartodos|iniciartransacao|inserir|ler|lernl|lernovalinha|vaparacampo|vaparapagina)\\b" }
			]
		},
		"booleans": {
			"patterns": [
				{ "name": "constant.language.boolean.true.lsp", "match": "(?i)\\b(cverdadeiro)\\b" },
				{ "name": "constant.language.boolean.false.lsp", "match": "(?i)\\b(cfalso)\\b" }
			]
		},
		"operadores": {
			"patterns": [
				{ "name": "keyword.operator.lsp", "match": "(\\+\\+|--|>=|<=|<>|\\+|-|\\*|/|=|>|<)" }
			]
		},
		"declaracoes": {
			"match": "(?i)\\b(Definir)\\s+(Cursor|Tabela|Lista|Alfa|Numero|Data|Funcao|Blob|Boleano)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
			"captures": {
				"1": { "name": "keyword.control.lsp" },
				"2": { "name": "storage.type.primitive.lsp" },
				"3": { "name": "entity.name.type.class.lsp" }
			}
		},
		"metodos_objetos": {
			"name": "entity.name.method.lsp",
			"match": "(?<=\\.)(?i)(AbrirCursor|FecharCursor|Achou|NaoAchou|Proximo|SQL|DefinirCampos|EfetivarCampos|AdicionarCampo|Adicionar|Inserir|Editar|Gravar|Cancelar|Excluir|Primeiro|Ultimo|Anterior|SetarChave|EditarChave|VaiParaChave|NumReg|SetaNumReg|IDA|FDA|QtdRegistros|Limpar|Chave|Executar|CriarLinha|DesatLimpezaParamEnt|AtivaLimpezaParamEnt|LimparParamsEntrada)\\b"
		},
		"propriedades_objetos": {
			"name": "variable.other.property.lsp",
			"match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b"
		},
		"funcoes_nativas": {
			"patterns": [
				{ "name": "support.function.basicas.lsp", "match": "(?<!\\.)(?i)\\b(Mensagem|ExecSQL|ExecSQLEx|IniciarTransacao|FinalizarTransacao|DesfazerTransacao|SQL_Criar|SQL_UsarSqlSenior2|SQL_UsarAbrangencia|SQL_DefinirComando|SQL_DefinirInteiro|SQL_DefinirFlutuante|SQL_DefinirAlfa|SQL_DefinirData|SQL_AbrirCursor|SQL_EOF|SQL_RetornarInteiro|SQL_RetornarFlutuante|SQL_RetornarAlfa|SQL_RetornarData|SQL_Proximo|SQL_FecharCursor|SQL_Destruir|CriaView|ExecutarComandoSQL|SetarFiltroSql|SelecaoTabelas)\\b" },
				{ "name": "support.function.conversao.lsp", "match": "(?<!\\.)(?i)\\b(MontaData|DesmontaData|ConverteMascara|IntParaAlfa|AlfaParaInt|FormatarN|EntradaValor|TamanhoAlfa|CopiarAlfa|DeletarAlfa|InserirAlfa|PosicaoAlfa|PosicaoStr|SubstAlfa|SubstAlfaUmaVez|QuebraTexto|LimpaEspacos|LimpaEspacosDireita|LimpaEspacosEsquerda|RetiraCaracteresEspeciais|RetiraAcentuacao|IntParaStr|RetornaAscII|TruncarValor|VerificaNumero|VerificaValor)\\b" },
				{ "name": "support.function.listasjson.lsp", "match": "(?<!\\.)(?i)\\b(ListaRegraCriarLista|ListaRegraLiberarLista|ListaRegraCarregarJson|ListaRegraObterValorAlfa|ListaRegraObterValorNumero|ListaRegraObterValorData|ListaRegraPrimeiro|ListaRegraProximo|ListaRegraAnterior|ListaRegraIrPara|ListaRegraFim|ListaRegraNovaLinha|ListaRegraSalvarLinha|ListaRegraAddValorLinhaAlfa|ListaRegraAddValorLinhaNumero|ListaRegraAddValorLinhaData|ListaRegraPodeIncluir|ListaRegraPodeAlterar|ListaRegraEmInclusao|ListaRegraTotalLinhas|ListaRegraAddProcurarAlfa|ListaRegraAddProcurarNumero|ListaRegraAddProcurarData|ListaRegraInicializarProcurar|ListaRegraProcurarAlfa|ListaRegraProcurarNumero|ListaRegraProcurarData|ListaRegraProcurarRegistro|ListaRegraProcurarAnterior|ListaRegraProcurarProximo|ValorElementoJson)\\b" },
				{ "name": "support.function.contabilfiscal.lsp", "match": "(?<!\\.)(?i)\\b(SimulacaoIMP_Iniciar|SimulacaoIMP_Calcular|SimulacaoIMP_Finalizar|SimulacaoIMP_CalcularParcial|SimulacaoIMP_CR_Calcular|SimulacaoIMP_CR_CalcularParcial|RetornaValorPreviaCSLL|CadastrarInfAdicionaisICMS|ExportarLFPD_AtoCotepe7005|SelecionaDadosDIPI|VisaoContabil_Linha_Rotulo|VisaoContabil_Nivel_Conta|AgluCtbCriar|AgluCtbLibera|AgluCtbValorComp|OrcamentoCtaCtbIniciarMemoria|OrcamentoCtaCtbPreencherMemoria|OrcamentoCtaCtbAtualizarCtaPai|OrcamentoCtaCtbLiberarMemoria|LoteLctoCria|LoteLctoInicializa|LoteLctoInicializaDes|LoteLctoInicializaCon|LoteLctoAdicionaLcto|LoteLctoAdicionaLctoRet|LoteLctoAdicionaLctoDoc|LoteLctoAdicionaLctoObs|LoteLctoAdicionaLctoCgc|LoteLctoAdicionaRateio|LoteLctoAdicionaRateioRet|LoteLctoAdicionaRateioFin|LoteLctoAdicionaAuxiliar|LoteLctoAdicionaAuxiliarRet|LoteLctoGeraLote|LoteLctoGeraLoteRet|LoteLctoLibera|LoteLctoImportacaoSapiens|ConsistirLctoAContabilizar|LimpaRatOrcCtb|Saldo|SaldoMes|SaldoCompleto|SaldoContabilCompleto|SaldoProjeto|MontaSaldoAnteriorCliente|CriarEstruturaSaldoCcu|LimparEstruturaSaldoCcu|RetornaPagamentoNotaFiscal)\\b" },
				{ "name": "support.function.manufaturalogistica.lsp", "match": "(?<!\\.)(?i)\\b(ObterSequenciaPendenciaCarga|SugerirLoteUnico|SugerirLoteCriterio|MontaListaLotesSugeridos|LeLotesSubdivididos|Gerar_Log_Analise|Gerar_Log_Pedido|Gerar_Log_NotaSaida|Tracking_RegistrarDocumento|Tracking_RegistrarFase|Tracking_Cancelar|SinalizarFaturamentoWmsSenior|DefinirCategoriaPedidoWms|ApontarOPs|GerarSubprodutosOPModelo|IncluirComponenteOP|AdicionaComponenteModelo|AdicionaConsumoComponente|CriaNovoModelo|LeMemListCompPro|LeMemListCompPro_2|LeMemListCompPro_3|ComposicaoProduto|ComposicaoProduto_2|ComposicaoProduto_3|ComposicaoProduto_4|BaixarComponentes|RetornarServicoOP|RecalcularOCServico|RemeterRetornarServico|ForcarFimEstagioOperacao|TrocarOpcaoOperacaoOP|InserirPassoPlanoExecucao|LeMemListProOP|fun_CancelaSaldoRequisicoes|ConsiderarItemContrato)\\b" },
				{ "name": "support.function.sistema.lsp", "match": "(?<!\\.)(?i)\\b(OtimizarAbrangencia|MontaAbrangencia|RetornarSerieNotaFiscal|SapiensSID|SapiensSIDEx|CarregarCSVparaPlataforma|AgendarExecucaoWebserviceEx|AbrirTelaSistema|SetaNumeroTelaEntrada|SetaAlfaTelaEntrada|SetaParamBuscaTabPreco|NomeCompletoUsuario|UltimoDia|RetDiaUtilAntPos|PegaUltimoNum|DesItemLista|MontaNumLancamento|LeMemListCcc|BuscaVlrCccProduto|GravaMemListCcc|BuscaMascModPlano|LerPedidosCanSub|LeMemListAnaEmbFil|LeDadosProdutoMinuta|LeDadosComponentesMinuta|RetornarQuantidadeLoteUtilizada|RowNum|PegarTipoVar|PegarValorVarAlf|PegarValorVarNum|SetarValorVarAlf|SetarValorVarNum|BuscaLinhaTexto|ObterProximoId|IncrementarCodigoAlfa|GerarVidUtilInicial)\\b" }
			]
		},
		"funcoes_gigante_comunidade": {
