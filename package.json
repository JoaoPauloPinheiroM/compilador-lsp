{
  "name": "lsp-senior",
  "displayName": "LSP Senior Pro",
  "description": "Extensão definitiva e compilador para Linguagem Senior de Programação",
  "version": "1.0.0",
  "publisher": "PMSystem",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:lsp"
  ],
  "main": "./out/extension/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaopaulopinheiro59675/lsp-senior-pro.git"
  },
  "license": "MIT",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "node -r ts-node/register -e \"require('./tests/lexer.spec.ts');require('./tests/parser.spec.ts');require('./tests/interpreter.spec.ts');require('./tests/transpiler.spec.ts');\""
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "vsce": "^2.15.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lsp",
        "extensions": [".lsp", ".sgi", ".gra", ".ger", ".rel", ".apu"],
        "aliases": ["LSP", "Senior"],
        "configuration": "./lsp-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lsp",
        "scopeName": "source.lsp",
        "path": "./syntaxes/lsp.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lsp",
        "path": "./snippets/lsp.json"
      }
    ]
  }
}
